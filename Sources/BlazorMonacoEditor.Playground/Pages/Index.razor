@page "/"
@using BlazorMonacoEditor.Services
@using BlazorMonacoEditor.Roslyn.Scaffolding
@inject IMonacoInterop MonacoInterop
@inject IndexViewModel DataContext

<div class="vh-100 d-flex flex-column overflow-hidden">
    <div class="m-2 flex-shrink-0">
        <div class=" d-flex my-1 gap-1 flex-wrap">
            <div class="input-group w-auto">
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="checkbox" id="isDiffEnabled" @bind="@DataContext.IsDiffEnabled"/>
                </div>
                <label for="isDiffEnabled" class="input-group-text">Diff</label>
            </div>
            
            <div class="input-group w-auto">
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="checkbox" id="isVisible" @bind="@DataContext.IsVisible"/>
                </div>
                <label for="isVisible" class="input-group-text">Is Visible</label>
            </div>

            <div class="input-group w-auto">
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="checkbox" id="showLineNumbers" @bind="@DataContext.ShowLineNumbers"/>
                </div>
                <label for="showLineNumbers" class="input-group-text">Show Line Numbers</label>
            </div>

            <div class="input-group w-auto">
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="checkbox" id="showMap" @bind="@DataContext.ShowCodeMap"/>
                </div>
                <label for="showMap" class="input-group-text">Show Map</label>
            </div>


            <div class="input-group w-auto">
                <select @bind="@DataContext.DocumentIdAsString"
                        class="form-select flex-shrink-1">
                    @foreach (var documentId in DataContext.Documents)
                    {
                        <option value="@(DocumentIdTypeConverter.Instance.ConvertToString(documentId))">
                            @documentId
                        </option>
                    }
                </select>
                <button class="btn btn-outline-secondary" id="addDocument" @onclick="@(async () => { DataContext.DocumentId = DataContext.AddDocument().Id; })">Add</button>
            </div>

            <select @bind="@DataContext.Theme"
                    class="form-select w-auto">
                @foreach (var theme in DataContext.KnownThemes)
                {
                    <option value="@theme">
                        @theme
                    </option>
                }
            </select>

            <select @bind="@DataContext.LanguageId"
                    class="form-select w-auto">
                @foreach (var languageId in DataContext.KnownLanguages)
                {
                    <option value="@languageId">
                        @languageId
                    </option>
                }
            </select>

            <div class="flex-grow-1"></div>
        </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
        @if (DataContext.IsVisible)
        {
            @if (!DataContext.IsDiffEnabled)
            {
                <MonacoEditor Theme="@DataContext.Theme"
                              @bind-LanguageId="@DataContext.LanguageId"
                              ShowLineNumbers="@DataContext.ShowLineNumbers"
                              ShowCodeMap="@DataContext.ShowCodeMap"
                              TextModel="@DataContext.TextModel"
                              />
            }
            else
            {
                <MonacoDiffEditor Theme="@DataContext.Theme"
                              @bind-LanguageId="@DataContext.LanguageId"
                              ShowLineNumbers="@DataContext.ShowLineNumbers"
                              ShowCodeMap="@DataContext.ShowCodeMap"
                              OriginalEditable="true"
                              OriginalTextModel="@DataContext.TextModel"
                              ModifiedTextModel="@DataContext.DiffTextModel"
                              />
            }
        }
    </div>
</div>

